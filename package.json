{
  "name": "directorai",
  "version": "1.0.0",
  "private": true,
  "description": "DirectorAI — AI Editing Copilot for Adobe Premiere Pro",
  "author": "DirectorAI Team",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev --parallel",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "bench:perf": "tsx tools/perf-bench.ts",
    "bench:memory": "tsx --expose-gc tools/memory-soak.ts",
    "bundle:ccx": "tsx tools/bundle-ccx.ts",
    "bundle:sample": "tsx tools/bundle-sample.ts",
    "survey:send": "tsx tools/survey-schedule.ts send",
    "survey:next": "tsx tools/survey-schedule.ts next",
    "sdk:surface": "tsx tools/sdk-surface-diff.ts",
    "license:keygen": "tsx tools/generate-license-keys.ts",
    "verify": "tsx tools/verify-precheck.ts",
    "smoke:uxp": "tsx tools/smoke-uxp.ts",
    "smoke:sentry": "tsx tools/smoke-sentry.ts",
    "smoke:stripe": "tsx tools/smoke-stripe.ts",
    "smoke:dns": "tsx tools/smoke-dns.ts",
    "diagnose:v2": "tsx tools/diagnose-v2.ts",
    "start:v2": "pwsh tools/start-v2.ps1",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.7.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.30.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "tsx": "^4.22.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.59.4",
    "vitest": "^2.1.2",
    "ws": "^8.18.0",
    "@types/ws": "^8.5.13",
    "yazl": "^3.3.1",
    "@types/yazl": "^3.3.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
