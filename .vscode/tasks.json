{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "shell",
      "command": "pnpm build",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "test",
      "type": "shell",
      "command": "pnpm test",
      "group": { "kind": "test", "isDefault": true }
    },
    {
      "label": "lint",
      "type": "shell",
      "command": "pnpm lint"
    },
    {
      "label": "typecheck",
      "type": "shell",
      "command": "pnpm typecheck"
    }
  ]
}
