{
  "name": "@directorai/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "bin": {
    "directorai-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@directorai/config": "workspace:*",
    "@directorai/core": "workspace:*",
    "@directorai/cut-planner": "workspace:*",
    "@directorai/llm-client": "workspace:*",
    "@directorai/premiere-adapter": "workspace:*",
    "@directorai/shared": "workspace:*",
    "@directorai/style-engine": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
