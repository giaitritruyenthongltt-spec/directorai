{
  "manifestVersion": 5,
  "id": "com.directorai.panel",
  "name": "DirectorAI",
  "version": "0.2.0",
  "main": "index.html",
  "host": {
    "app": "premierepro",
    "minVersion": "25.1.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "directorai-main",
      "label": {
        "default": "DirectorAI"
      },
      "minimumSize": { "width": 320, "height": 480 },
      "maximumSize": { "width": 800, "height": 2048 },
      "preferredDockedSize": { "width": 400, "height": 600 },
      "icons": [
        {
          "width": 23,
          "height": 23,
          "path": "icons/icon23.png",
          "scale": [1, 2]
        }
      ]
    }
  ],
  "icons": [
    {
      "width": 48,
      "height": 48,
      "path": "icons/icon23.png",
      "scale": [1, 2],
      "species": ["pluginList"]
    }
  ],
  "requiredPermissions": {
    "allowCodeGenerationFromStrings": false,
    "network": {
      "domains": [
        "ws://127.0.0.1:7778",
        "http://127.0.0.1:7777",
        "ws://localhost:7778",
        "http://localhost:7777"
      ]
    },
    "localFileSystem": "request",
    "webScripting": {
      "enabled": true,
      "allow": ["127.0.0.1", "localhost"]
    }
  }
}
