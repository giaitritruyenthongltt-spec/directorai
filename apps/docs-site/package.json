{
  "name": "@directorai/docs-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && node dist-ts/build.js && pnpm run build:api",
    "build:api": "typedoc --options typedoc.json",
    "dev": "tsx watch src/dev-server.ts",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "marked": "^14.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "typedoc": "^0.26.10",
    "vitest": "^2.1.2"
  }
}
