# DirectorAI environment template.
# Copy to `.env` and fill in. `.env` is gitignored.
#
# Only the variables you actually use need to be set; every server
# feature is gated to a no-op when its key is absent (per ADR-0008
# and Track-C documentation).

# ─── Server config ────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
SERVER_HOST=127.0.0.1
SERVER_PORT=7777
WS_PORT=7778

# ─── LLM router (V0 Sprint Verification: paste at least one) ──────────────
# Anthropic primary. The legacy single-key wiring still works.
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-7
# Optional providers (multi-LLM router, P5.04)
OPENAI_API_KEY=
GEMINI_API_KEY=

# ─── Sentry (P4.09 / P4.10) ───────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_RELEASE=

# ─── Telemetry (P4.12 / P4.13) ────────────────────────────────────────────
TELEMETRY_ENABLED=false
TELEMETRY_STORE_PATH=

# ─── License (P4.17 / P4.20) ──────────────────────────────────────────────
# Paste the public key from `.secrets/license-public.pem`. Multi-line
# values need surrounding double-quotes in some shells; on Windows
# PowerShell use:
#     $env:DIRECTORAI_LICENSE_PUBLIC_KEY = Get-Content .secrets/license-public.pem -Raw
DIRECTORAI_LICENSE_PUBLIC_KEY=
# Private key — ONLY on the box that runs the Stripe webhook. Never
# put this on a panel-side machine.
DIRECTORAI_LICENSE_PRIVATE_KEY=

# ─── Stripe (P4.18 / P4.41) ───────────────────────────────────────────────
# Test mode for local dev:
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Premiere / NLE host ──────────────────────────────────────────────────
# Force the host when probing fails. Values: uxp / davinci / mock.
DIRECTORAI_NLE_HOST=
# MOGRT default template (P1.17 / A.1 cleanup).
DIRECTORAI_MOGRT_TEMPLATE=

# ─── Plugin loader (P5.01d) ───────────────────────────────────────────────
# Override the plugins directory. Default: ./plugins
DIRECTORAI_PLUGINS_DIR=

# ─── Context engine (Python sidecar) ──────────────────────────────────────
CONTEXT_ENGINE_URL=http://127.0.0.1:8000
WHISPER_MODEL=base

# ─── Marketplace / Teams (P5 stubs, deploy when ready) ────────────────────
MARKETPLACE_PORT=7820
MARKETPLACE_ADMIN_TOKEN=
DISCORD_WAITLIST_WEBHOOK=
DISCORD_SURVEY_WEBHOOK=
TALLY_SURVEY_URL=

# ─── Mobile companion / portal ────────────────────────────────────────────
PORTAL_PORT=7780
LANDING_PORT=7795
MARKETING_PORT=7800
DOCS_PORT=7790
