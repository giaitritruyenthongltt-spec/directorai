{
  "name": "@directorai/sdk",
  "version": "1.0.0",
  "private": false,
  "description": "Public SDK for DirectorAI plugin authors.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./manifest": "./src/manifest.ts",
    "./plugin": "./src/plugin.ts"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@directorai/core": "workspace:*",
    "@directorai/cut-planner": "workspace:*",
    "@directorai/effect-library": "workspace:*",
    "@directorai/llm-client": "workspace:*",
    "@directorai/premiere-adapter": "workspace:*",
    "@directorai/style-engine": "workspace:*",
    "@directorai/telemetry": "workspace:*",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
